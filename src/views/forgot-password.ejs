<%- include('partials/head', { pageTitle, bodyClass: 'auth-page' }) %>
<main class="auth-shell">
  <section class="auth-card hero-card">
    <div class="eyebrow">Recuperação</div>
    <h1>Vamos gerar um novo link de acesso.</h1>
    <p class="lede">Se o e-mail existir na base, você recebe o link de redefinição para voltar ao painel.</p>
  </section>

  <section class="auth-card form-card">
    <h2>Recuperar senha</h2>

    <% if (error) { %>
      <div class="alert alert-info"><%= error %></div>
    <% } %>

    <% if (success) { %>
      <div class="alert alert-success"><%= success %></div>
    <% } %>

    <% if (devResetUrl) { %>
      <div class="dev-box">
        <strong>Link de desenvolvimento:</strong>
        <a href="<%= devResetUrl %>"><%= devResetUrl %></a>
      </div>
    <% } %>

    <form method="post" action="/forgot-password" class="stack">
      <label>
        <span>E-mail</span>
        <input type="email" name="email" value="<%= form.email || '' %>" autocomplete="email" required />
      </label>
      <button class="btn btn-primary" type="submit">Enviar link</button>
    </form>

    <div class="auth-links">
      <a href="/login">Voltar para login</a>
    </div>
  </section>
</main>
<%- include('partials/footer') %>
