<%- include('partials/head', { pageTitle, bodyClass: 'auth-page' }) %>
<main class="auth-shell">
  <section class="auth-card hero-card">
    <div class="eyebrow">Painel do administrador</div>
    <h1>Entre na central de comandas.</h1>
    <p class="lede">Acompanhe pedidos, gere QR Codes e envie o aviso sonoro assim que estiver pronto.</p>
    <div class="hero-badges">
      <span>QR Code único</span>
      <span>Realtime</span>
      <span>Som + vibração</span>
    </div>
  </section>

  <section class="auth-card form-card">
    <h2>Login</h2>
    <p class="muted">Use seu e-mail e senha para acessar o dashboard.</p>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <form method="post" action="/login" class="stack">
      <label>
        <span>E-mail</span>
        <input type="email" name="email" value="<%= form.email || '' %>" autocomplete="email" required />
      </label>
      <label>
        <span>Senha</span>
        <input type="password" name="password" autocomplete="current-password" required />
      </label>
      <button class="btn btn-primary" type="submit">Entrar</button>
    </form>

    <div class="auth-links">
      <a href="/forgot-password">Esqueci minha senha</a>
      <a href="/register">Criar conta</a>
    </div>
  </section>
</main>
<%- include('partials/footer') %>
